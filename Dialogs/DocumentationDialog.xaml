<Window x:Class="FileFinder.Dialogs.DocumentationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:l="clr-namespace:FileFinder.Localization"
        Title="{l:Loc MenuDocumentation}"
        Width="920" Height="680" MinWidth="640" MinHeight="420"
        Icon="FileFinder.ico"
        Background="{StaticResource BackgroundBrush}"
        FontFamily="Segoe UI"
        WindowStartupLocation="CenterOwner">
    <DockPanel>
        <!-- Bottom buttons -->
        <Border DockPanel.Dock="Bottom" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
            <Grid Margin="16,10">
                <Button Content="{l:Loc DocsOpenInBrowser}" Height="34" Padding="14,0"
                        HorizontalAlignment="Left" Style="{StaticResource SecondaryButton}"
                        Click="OpenInBrowser_Click"/>
                <Button Content="{l:Loc Close}" Width="110" Height="34"
                        HorizontalAlignment="Right" Style="{StaticResource PrimaryButton}"
                        Click="Close_Click" IsDefault="True"/>
            </Grid>
        </Border>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="236"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left task panel: sections -->
            <Border Grid.Column="0" Background="{StaticResource SidebarBrush}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="{l:Loc MenuDocumentation}"
                               Foreground="#94A3B8" FontSize="11" FontWeight="SemiBold"
                               Margin="18,18,18,10"/>
                    <ListBox x:Name="SectionList" BorderThickness="0" Background="Transparent"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             SelectionChanged="SectionList_SelectionChanged">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Foreground" Value="#CBD5E1"/>
                                <Setter Property="FontSize" Value="13"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="bd" Padding="16,9" Background="Transparent"
                                                    BorderThickness="3,0,0,0" BorderBrush="Transparent">
                                                <ContentPresenter VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bd" Property="Background" Value="#27364B"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="bd" Property="Background" Value="#0F172A"/>
                                                    <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- Content -->
            <Border Grid.Column="1" Background="{StaticResource SurfaceBrush}">
                <FlowDocumentScrollViewer x:Name="Viewer" IsToolBarVisible="False"
                                          VerticalScrollBarVisibility="Auto" Padding="0"/>
            </Border>
        </Grid>
    </DockPanel>
</Window>
