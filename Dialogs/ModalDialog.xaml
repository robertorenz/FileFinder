<Window x:Class="FileFinder.Dialogs.ModalDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStartupLocation="CenterOwner"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Title="FileFinder">
    <Border Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
            CornerRadius="10" MinWidth="380" MaxWidth="520">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.28" Color="#0F172A"/>
        </Border.Effect>
        <StackPanel Margin="0">
            <Border CornerRadius="10,10,0,0" Padding="20,16" x:Name="HeaderBar"
                    Background="{StaticResource PrimaryBrush}">
                <TextBlock x:Name="TitleText" Text="FileFinder" FontSize="15" FontWeight="SemiBold"
                           Foreground="White"/>
            </Border>
            <TextBlock x:Name="MessageText" Margin="20,18,20,8" TextWrapping="Wrap"
                       FontSize="13.5" Foreground="{StaticResource TextBrush}"
                       LineHeight="20"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="20,12,20,18">
                <Button x:Name="CancelButton" Content="Cancel" Width="96" Height="34"
                        Style="{StaticResource SecondaryButton}" Margin="0,0,10,0"
                        Visibility="Collapsed" Click="Cancel_Click"/>
                <Button x:Name="OkButton" Content="OK" Width="96" Height="34"
                        Style="{StaticResource PrimaryButton}" Click="Ok_Click" IsDefault="True"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
