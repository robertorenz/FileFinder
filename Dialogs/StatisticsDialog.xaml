<Window x:Class="FileFinder.Dialogs.StatisticsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStartupLocation="CenterOwner"
        SizeToContent="Height" Width="560"
        ResizeMode="NoResize" ShowInTaskbar="False"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Title="Index Statistics">
    <Border Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.28" Color="#0F172A"/>
        </Border.Effect>
        <StackPanel>
            <!-- Header -->
            <Border CornerRadius="10,10,0,0" Padding="22,16" Background="{StaticResource PrimaryBrush}">
                <StackPanel>
                    <TextBlock Text="Index Statistics" FontSize="16" FontWeight="SemiBold" Foreground="White"/>
                    <TextBlock x:Name="SubtitleText" FontSize="12" Foreground="#BFDBFE" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>

            <!-- Key / value rows -->
            <StackPanel x:Name="RowsPanel" Margin="22,18,22,6"/>

            <!-- Top file types -->
            <StackPanel x:Name="ExtSection" Margin="22,6,22,6">
                <TextBlock Text="TOP FILE TYPES" FontSize="11" FontWeight="SemiBold"
                           Foreground="{StaticResource MutedBrush}" Margin="0,8,0,8"/>
                <ItemsControl x:Name="ExtList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Ext}" FontSize="12.5"
                                           Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
                                <Border Grid.Column="1" Background="{StaticResource BackgroundBrush}"
                                        CornerRadius="4" Height="10" VerticalAlignment="Center" Margin="0,0,12,0">
                                    <Border Background="{StaticResource PrimaryBrush}" CornerRadius="4"
                                            HorizontalAlignment="Left" Width="{Binding BarWidth}"/>
                                </Border>
                                <TextBlock Grid.Column="2" Text="{Binding CountText}" FontSize="12.5"
                                           Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center"
                                           MinWidth="64" TextAlignment="Right"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!-- Buttons -->
            <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Margin="0,10,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="22,14,22,16">
                    <Button x:Name="OpenFolderButton" Content="Open Cache Folder" Width="160" Height="34"
                            Style="{StaticResource SecondaryButton}" Margin="0,0,10,0" Click="OpenFolder_Click"/>
                    <Button Content="Close" Width="96" Height="34"
                            Style="{StaticResource PrimaryButton}" Click="Close_Click" IsDefault="True"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </Border>
</Window>
