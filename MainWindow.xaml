<Window x:Class="FileFinder.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FileFinder"
        xmlns:vm="clr-namespace:FileFinder.ViewModels"
        xmlns:l="clr-namespace:FileFinder.Localization"
        mc:Ignorable="d"
        Title="{l:Loc WindowTitle}" Height="660" Width="1040"
        MinHeight="440" MinWidth="720"
        Background="{StaticResource BackgroundBrush}"
        FontFamily="Segoe UI"
        Icon="FileFinder.ico"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.InputBindings>
        <KeyBinding Modifiers="Control" Key="I" Command="{Binding ShowStatisticsCommand}"/>
        <KeyBinding Modifiers="Control" Key="B" Command="{Binding BenchmarkCommand}"/>
        <KeyBinding Modifiers="Control" Key="OemComma" Command="{Binding PreferencesCommand}"/>
    </Window.InputBindings>

    <Window.Resources>
        <!-- Carries the VM into DataGridColumn.Visibility bindings -->
        <vm:BindingProxy x:Key="proxy" Data="{Binding}"/>
    </Window.Resources>

    <DockPanel LastChildFill="True">

        <!-- ============ Menu bar ============ -->
        <Border DockPanel.Dock="Top" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <Menu Background="Transparent" Foreground="{StaticResource TextBrush}"
                  Padding="6,3" FontSize="12.5">
                <MenuItem Header="{l:Loc MenuFile}">
                    <MenuItem Header="{l:Loc BuildIndex}" Command="{Binding IndexCommand}"/>
                    <MenuItem Header="{l:Loc ClearIndex}" Command="{Binding ClearIndexCommand}"/>
                    <Separator/>
                    <MenuItem Header="{l:Loc MenuOpenCacheFolder}" Command="{Binding OpenCacheFolderCommand}"/>
                    <MenuItem Header="{l:Loc MenuPreferences}" Command="{Binding PreferencesCommand}"
                              InputGestureText="Ctrl+,"/>
                    <Separator/>
                    <MenuItem Header="{l:Loc MenuExit}" Click="Exit_Click"/>
                </MenuItem>
                <MenuItem Header="{l:Loc MenuView}">
                    <MenuItem Header="{l:Loc MenuStatistics}" Command="{Binding ShowStatisticsCommand}"
                              InputGestureText="Ctrl+I"/>
                    <MenuItem Header="{l:Loc MenuBenchmark}" Command="{Binding BenchmarkCommand}"
                              InputGestureText="Ctrl+B"/>
                </MenuItem>
                <MenuItem Header="{l:Loc MenuHelp}">
                    <MenuItem Header="{l:Loc MenuAbout}" Command="{Binding AboutCommand}"/>
                </MenuItem>
            </Menu>
        </Border>

        <!-- ============ Search bar ============ -->
        <Border DockPanel.Dock="Top" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="24,16">
            <StackPanel>
                <Border Background="{StaticResource BackgroundBrush}" CornerRadius="9"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        Padding="16,0" Height="48">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="🔍" FontSize="16" VerticalAlignment="Center"
                                   Foreground="{StaticResource MutedBrush}" Margin="0,0,12,0"/>
                        <Grid Grid.Column="1">
                            <TextBox x:Name="SearchInput" Style="{StaticResource SearchBox}"
                                     Text="{Binding Query, UpdateSourceTrigger=PropertyChanged, Delay=0}"/>
                            <TextBlock Text="{l:Loc SearchPlaceholder}"
                                       Foreground="{StaticResource MutedBrush}" FontSize="15"
                                       VerticalAlignment="Center" IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=SearchInput}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Grid>
                </Border>

                <Grid Margin="2,12,2,0">
                    <TextBlock Text="{Binding IndexSummary}" Foreground="{StaticResource MutedBrush}"
                               FontSize="12.5" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding ResultCountText}" Foreground="{StaticResource PrimaryBrush}"
                               FontWeight="SemiBold" FontSize="12.5" HorizontalAlignment="Right"
                               VerticalAlignment="Center"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- ============ Status / progress bar ============ -->
        <Border DockPanel.Dock="Bottom" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="24,0" Height="44">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding StatusText}" VerticalAlignment="Center"
                           Foreground="{StaticResource MutedBrush}" FontSize="12"
                           TextTrimming="CharacterEllipsis" Margin="0,0,16,0"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"
                            Visibility="{Binding IsIndexing, Converter={StaticResource BoolToVis}}">
                    <ProgressBar Width="150" Height="6" VerticalAlignment="Center"
                                 Background="{StaticResource BackgroundBrush}"
                                 Foreground="{StaticResource PrimaryBrush}" BorderThickness="0"
                                 IsIndeterminate="{Binding IsIndeterminate}"
                                 Value="{Binding ProgressValue}" Maximum="100"/>
                    <Button Content="{l:Loc CancelIndexing}" Padding="12,5" Margin="14,0,0,0"
                            FontSize="11.5" VerticalAlignment="Center"
                            Style="{StaticResource SecondaryButton}" Command="{Binding CancelCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ============ Results grid ============ -->
        <Border Margin="24,18,24,18" Background="{StaticResource SurfaceBrush}" CornerRadius="10"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="14" ShadowDepth="2" Opacity="0.06" Color="#0F172A"/>
            </Border.Effect>
            <DataGrid x:Name="ResultsGrid" ItemsSource="{Binding Results}"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      SelectionMode="Single" CanUserResizeRows="False"
                      MouseDoubleClick="ResultsGrid_MouseDoubleClick">
                <DataGrid.Resources>
                    <ContextMenu x:Key="RowMenu">
                        <MenuItem Header="{l:Loc CtxOpenFile}" FontWeight="SemiBold"
                                  Command="{Binding Data.OpenFileCommand, Source={StaticResource proxy}}"
                                  CommandParameter="{Binding}"/>
                        <MenuItem Header="{l:Loc CtxOpenWith}"
                                  Command="{Binding Data.OpenWithCommand, Source={StaticResource proxy}}"
                                  CommandParameter="{Binding}"/>
                        <MenuItem Header="{l:Loc CtxRunAsAdmin}"
                                  Command="{Binding Data.RunAsAdminCommand, Source={StaticResource proxy}}"
                                  CommandParameter="{Binding}"/>
                        <MenuItem Header="{l:Loc CtxOpenFolder}"
                                  Command="{Binding Data.OpenFolderCommand, Source={StaticResource proxy}}"
                                  CommandParameter="{Binding}"/>
                        <MenuItem Header="{l:Loc CtxOpenInTerminal}"
                                  Command="{Binding Data.OpenInTerminalCommand, Source={StaticResource proxy}}"
                                  CommandParameter="{Binding}"/>
                        <Separator/>
                        <MenuItem Header="{l:Loc CtxCopy}">
                            <MenuItem Header="{l:Loc CtxCopyFile}"
                                      Command="{Binding Data.CopyFileCommand, Source={StaticResource proxy}}"
                                      CommandParameter="{Binding}"/>
                            <MenuItem Header="{l:Loc CtxCopyFullPath}"
                                      Command="{Binding Data.CopyFullPathCommand, Source={StaticResource proxy}}"
                                      CommandParameter="{Binding}"/>
                            <MenuItem Header="{l:Loc CtxCopyFolderPath}"
                                      Command="{Binding Data.CopyFolderPathCommand, Source={StaticResource proxy}}"
                                      CommandParameter="{Binding}"/>
                            <MenuItem Header="{l:Loc CtxCopyFileName}"
                                      Command="{Binding Data.CopyFileNameCommand, Source={StaticResource proxy}}"
                                      CommandParameter="{Binding}"/>
                            <MenuItem Header="{l:Loc CtxCopyNameNoExt}"
                                      Command="{Binding Data.CopyNameNoExtCommand, Source={StaticResource proxy}}"
                                      CommandParameter="{Binding}"/>
                            <Separator/>
                            <MenuItem Header="{l:Loc CtxCopySize}"
                                      Command="{Binding Data.CopySizeCommand, Source={StaticResource proxy}}"
                                      CommandParameter="{Binding}"/>
                            <MenuItem Header="{l:Loc CtxCopyDate}"
                                      Command="{Binding Data.CopyDateCommand, Source={StaticResource proxy}}"
                                      CommandParameter="{Binding}"/>
                        </MenuItem>
                        <Separator/>
                        <MenuItem Header="{l:Loc CtxFindByType}"
                                  Command="{Binding Data.FindByTypeCommand, Source={StaticResource proxy}}"
                                  CommandParameter="{Binding}"/>
                        <MenuItem Header="{l:Loc CtxProperties}"
                                  Command="{Binding Data.PropertiesCommand, Source={StaticResource proxy}}"
                                  CommandParameter="{Binding}"/>
                    </ContextMenu>
                </DataGrid.Resources>
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                        <Setter Property="ContextMenu" Value="{StaticResource RowMenu}"/>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="{l:Loc ColName}" Binding="{Binding Name}" Width="2.2*"/>
                    <DataGridTextColumn Header="{l:Loc ColFolder}" Binding="{Binding Directory}" Width="3*"
                                        Visibility="{Binding Data.ShowFolderColumn, Source={StaticResource proxy}, Converter={StaticResource BoolToVis}}"/>
                    <DataGridTextColumn Header="{l:Loc ColType}" Binding="{Binding Extension}" Width="0.7*"
                                        Visibility="{Binding Data.ShowTypeColumn, Source={StaticResource proxy}, Converter={StaticResource BoolToVis}}"/>
                    <DataGridTextColumn Header="{l:Loc ColSize}" Binding="{Binding SizeText}" Width="0.8*"
                                        SortMemberPath="SizeBytes"
                                        Visibility="{Binding Data.ShowSizeColumn, Source={StaticResource proxy}, Converter={StaticResource BoolToVis}}"/>
                    <DataGridTextColumn Header="{l:Loc ColModified}" Binding="{Binding ModifiedText}" Width="1.3*"
                                        SortMemberPath="ModifiedRaw"
                                        Visibility="{Binding Data.ShowModifiedColumn, Source={StaticResource proxy}, Converter={StaticResource BoolToVis}}"/>
                    <DataGridTextColumn Header="{l:Loc ColAttributes}" Binding="{Binding AttributesText}" Width="0.7*"
                                        Visibility="{Binding Data.ShowAttributesColumn, Source={StaticResource proxy}, Converter={StaticResource BoolToVis}}"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </DockPanel>
</Window>
